        Position = UDim2.new(0.008, 0, 0.03, 0), ZIndex = 999, Parent = screenGui,
    })
    create("UIListLayout", {
        Padding = UDim.new(0, 4), VerticalAlignment = Enum.VerticalAlignment.Top,
        SortOrder = Enum.SortOrder.LayoutOrder, Parent = notifHolder,
    })
    self.notifyHolder = notifHolder

    -- Keybind panel
    local kbPanel = create("Frame", {
        BackgroundColor3 = C.BG, BackgroundTransparency = 0.03,
        AutomaticSize = Enum.AutomaticSize.Y, Size = UDim2.new(0, 104, 0, 25),
        Position = UDim2.new(0.0106, 0, 0.388, 0), BorderSizePixel = 0,
        Visible = false, ZIndex = 998, Parent = screenGui,
    })
    corner(kbPanel, 4); stroke(kbPanel, C.BORDER)
    self.keybindPanel = kbPanel
    local kbBar = create("Frame", {
        BackgroundColor3 = C.ELEMENT, Size = UDim2.new(1, 0, 0, 20), BorderSizePixel = 0, Parent = kbPanel,
    })
    corner(kbBar, 4)
    label(kbBar, "Binds", 12, C.TEXT, FONT, {Size = UDim2.new(1, 0, 1, 0)})
    local kbHolder = create("Frame", {
        BackgroundTransparency = 1, BorderSizePixel = 0,
        AutomaticSize = Enum.AutomaticSize.Y, Size = UDim2.new(1, 0, 0, 4),
        Position = UDim2.new(0, 0, 0, 20), Parent = kbPanel,
    })
    create("UIListLayout", {SortOrder = Enum.SortOrder.LayoutOrder, Parent = kbHolder})
    self._kbHolder = kbHolder

    self._kbUpdateConn = Services.Run_Service.RenderStepped:Connect(function()
        if not self.keybindPanel.Visible then return end
        for flag, frame in pairs(self._keybindFrames) do
            local data = Library.flags[flag]
            local lbl = self._keybindLabels[flag]
            if data and lbl then
                local kt = data.key and ("[" .. data.key .. "]") or "[N/A]"
                lbl.Text = kt .. " " .. (self._keybindNames[flag] or "keybind")
                lbl.TextColor3 = data.active and C.ACCENT or C.TEXT
            end
        end
    end)

    -- Color picker popup
    self:_makeColorPicker(screenGui)

    -- Menu keybind (handled by script's own InputBegan)
    self._menuKeybind = Enum.KeyCode.RightShift

    -- Close context popups on outside click
    Services.User_Input.InputBegan:Connect(function(input, gpe)
        if input.UserInputType ~= Enum.UserInputType.MouseButton1 and input.UserInputType ~= Enum.UserInputType.Touch then return end
        local mp = Services.User_Input:GetMouseLocation()
        for _, ctx in ipairs(self._openContexts) do
            if ctx.open.value and ctx.popup.Visible then
                local ap = ctx.popup.AbsolutePosition; local sz = ctx.popup.AbsoluteSize
                if mp.X < ap.X or mp.X > ap.X + sz.X or mp.Y < ap.Y or mp.Y > ap.Y + sz.Y then
                    ctx.open.value = false; ctx.popup.Visible = false
                end
            end
        end
    end)

    -- Drag
    local dragStart, startPos, dragging
    main.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragStart = input.Position; startPos = main.Position; dragging = true
        end
    end)
    Services.User_Input.InputChanged:Connect(function(input)
        if not dragging then return end
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            local d = input.Position - dragStart
            main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + d.X, startPos.Y.Scale, startPos.Y.Offset + d.Y)
        end
    end)
    Services.User_Input.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)

    return self
end

-- ==================== TAB ====================
function Library:CreateTab(name)
    local tabBtn = create("TextButton", {
        BackgroundColor3 = (#self.tabs == 0) and C.ELEMENT or C.DARK,
        TextColor3 = (#self.tabs == 0) and C.ACCENT or C.SUBTEXT,
        Text = name, TextSize = 13, FontFace = FONT,
        Size = UDim2.new(1, -16, 0, 30), BorderSizePixel = 0,
        AutoButtonColor = false, Parent = self._tabScroll,
    })
    corner(tabBtn, 4)

    local page = create("Frame", {
        BackgroundColor3 = C.BG, BackgroundTransparency = 0.03,
        Size = UDim2.new(1, 0, 1, 0), BorderSizePixel = 0,
        Visible = (#self.tabs == 0), Parent = self._pageFolder,
    })

    local leftCol = create("ScrollingFrame", {
        Active = true, BackgroundColor3 = C.DARK, BorderSizePixel = 0,
        Size = UDim2.new(0.5, -4, 1, -8), Position = UDim2.new(0, 4, 0, 4),
        ScrollBarThickness = 3, ScrollBarImageColor3 = C.SCROLL,
        CanvasSize = UDim2.new(0, 0, 0, 0), BottomImage = "", TopImage = "",
        Parent = page,
    })
    corner(leftCol, 4)
    local leftList = create("UIListLayout", {Padding = UDim.new(0, 4), SortOrder = Enum.SortOrder.LayoutOrder, Parent = leftCol})
    leftList:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        leftCol.CanvasSize = UDim2.new(0, 0, 0, leftList.AbsoluteContentSize.Y + 4)
    end)

    local rightCol = create("ScrollingFrame", {
        Active = true, BackgroundColor3 = C.DARK, BorderSizePixel = 0,
        Size = UDim2.new(0.5, -4, 1, -8), Position = UDim2.new(0.5, 0, 0, 4),
        ScrollBarThickness = 3, ScrollBarImageColor3 = C.SCROLL,
        CanvasSize = UDim2.new(0, 0, 0, 0), BottomImage = "", TopImage = "",
        Parent = page,
    })
    corner(rightCol, 4)
    local rightList = create("UIListLayout", {Padding = UDim.new(0, 4), SortOrder = Enum.SortOrder.LayoutOrder, Parent = rightCol})
    rightList:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        rightCol.CanvasSize = UDim2.new(0, 0, 0, rightList.AbsoluteContentSize.Y + 4)
    end)

    local tabData = {
        button = tabBtn, page = page,
        LeftColumn = {col = leftCol, list = leftList},
        RightColumn = {col = rightCol, list = rightList},
        name = name,
    }
    tabBtn.MouseButton1Click:Connect(function() self:_switchTab(tabData) end)
    table.insert(self.tabs, tabData)
    if #self.tabs == 1 then self.activeTab = tabData end
    return tabData
end

function Library:_switchTab(tabData)
    for _, t in ipairs(self.tabs) do
        local active = (t == tabData)
        t.page.Visible = active
        tween(t.button, {BackgroundColor3 = active and C.ELEMENT or C.DARK}, TWEEN_FAST):Play()
        tween(t.button, {TextColor3 = active and C.ACCENT or C.SUBTEXT}, TWEEN_FAST):Play()
    end
    self.activeTab = tabData
end

-- ==================== MULTI TAB ====================
function Library:CreateMultiTab(parent, name)
    if not parent._multiTabs then
        parent._multiTabs = {}; parent._multiActive = nil
        local bar = create("Frame", {
            BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 24),
            Position = UDim2.new(0, 4, 0, 0), BorderSizePixel = 0, Parent = parent.page,
        })
        parent._mtBar = bar
        create("UIListLayout", {FillDirection = Enum.FillDirection.Horizontal, SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 3), Parent = bar})
        parent.LeftColumn.col.Position = UDim2.new(0, 4, 0, 28)
        parent.LeftColumn.col.Size = UDim2.new(0.5, -4, 1, -32)
        parent.RightColumn.col.Position = UDim2.new(0.5, 0, 0, 28)
        parent.RightColumn.col.Size = UDim2.new(0.5, -4, 1, -32)
    end

    local mtBtn = create("TextButton", {
        BackgroundColor3 = (#parent._multiTabs == 0) and C.ELEMENT or C.DARK,
        TextColor3 = (#parent._multiTabs == 0) and C.ACCENT or C.SUBTEXT,
        Text = name, TextSize = 12, FontFace = FONT,
        Size = UDim2.new(0, 80, 0, 22), BorderSizePixel = 0,
        AutoButtonColor = false, Parent = parent._mtBar,
    })
    corner(mtBtn, 4)

    local mtActive = (#parent._multiTabs == 0)
    parent.LeftColumn.col.Visible = mtActive
    parent.RightColumn.col.Visible = mtActive

    local mtData = {button = mtBtn, name = name, LeftColumn = parent.LeftColumn, RightColumn = parent.RightColumn}

    mtBtn.MouseButton1Click:Connect(function()
        for _, mt in ipairs(parent._multiTabs) do
            local active = (mt == mtData)
            tween(mt.button, {BackgroundColor3 = active and C.ELEMENT or C.DARK}, TWEEN_FAST):Play()
            tween(mt.button, {TextColor3 = active and C.ACCENT or C.SUBTEXT}, TWEEN_FAST):Play()
        end
        parent.LeftColumn.col.Visible = true
        parent.RightColumn.col.Visible = true
        parent._multiActive = mtData
    end)

    table.insert(parent._multiTabs, mtData)
    if #parent._multiTabs == 1 then parent._multiActive = mtData end
    return mtData
end

-- ==================== SECTION ====================
function Library:CreateSection(parent, name, side)
    local col
    if type(parent) == "table" and parent.col then
        col = parent.col
    elseif side == "right" then
        col = parent.RightColumn and parent.RightColumn.col or parent.col
    else
        col = parent.LeftColumn and parent.LeftColumn.col or parent.col
    end

    local section = create("Frame", {
        BackgroundColor3 = C.SURFACE, BorderSizePixel = 0,
        AutomaticSize = Enum.AutomaticSize.Y, Size = UDim2.new(1, 0, 0, 0),
        Parent = col,
    })
    corner(section, 4)

    local header = create("Frame", {
        BackgroundColor3 = C.SURFACE, Size = UDim2.new(1, 0, 0, 22), BorderSizePixel = 0, Parent = section,
    })
    corner(header, 4)
    label(header, name, 11, C.SUBTEXT, FONT_BOLD, {
        Position = UDim2.new(0, 8, 0, 0), Size = UDim2.new(1, -16, 1, 0),
        TextYAlignment = Enum.TextYAlignment.Center,
    })
    create("Frame", {
        BackgroundColor3 = C.BORDER, BackgroundTransparency = 0.7,
        Size = UDim2.new(1, -8, 0, 1), Position = UDim2.new(0, 4, 1, 0),
        BorderSizePixel = 0, Parent = header,
    })

    local inner = create("Frame", {
        BackgroundColor3 = C.DARK, BorderSizePixel = 0,
        AutomaticSize = Enum.AutomaticSize.Y, Size = UDim2.new(1, 0, 0, 0),
        Position = UDim2.new(0, 0, 0, 22), Parent = section,
    })
    corner(inner, 4)
    create("UIListLayout", {HorizontalFlex = Enum.UIFlexAlignment.Fill, SortOrder = Enum.SortOrder.LayoutOrder, Parent = inner})

    return {frame = section, inner = inner, elements = inner, name = name}
end


-- ==================== TOGGLE ====================
function Library:CreateToggle(section, config)
    local name = config.name or "Toggle"; local flag = config.flag or name:lower():gsub("%s+", "_")
    local default = config.default or false; local cb = config.callback or function() end
    Library.flags[flag] = default

    local frame = create("Frame", {
        BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 26), BorderSizePixel = 0,
        Parent = section.elements,
    })
    local check = create("Frame", {
        BackgroundColor3 = default and C.ACCENT or C.OFF,
        Size = UDim2.new(0, 16, 0, 16), Position = UDim2.new(0, 6, 0, 5),
        BorderSizePixel = 0, Parent = frame,
    })
    corner(check, 3); stroke(check, default and C.ACCENT or C.BORDER)
    local checkMark = create("TextLabel", {
        Text = "\226\156\148", TextSize = 11, TextColor3 = C.WHITE, FontFace = FONT_BOLD,
        BackgroundTransparency = 1, Size = UDim2.new(1, 0, 1, 0), BorderSizePixel = 0,
        Visible = default, Parent = check,
    })
    local nameLabel = label(frame, name, 13, C.TEXT, FONT, {
        Position = UDim2.new(0, 28, 0, 0), Size = UDim2.new(1, -80, 1, 0),
        TextYAlignment = Enum.TextYAlignment.Center,
    })

    local toggled = default
    local extrasFrame = create("Frame", {
        BackgroundTransparency = 1, Size = UDim2.new(0, 0, 1, 0),
        Position = UDim2.new(1, -60, 0, 0), BorderSizePixel = 0, Parent = frame,
    })
    create("UIListLayout", {
        HorizontalAlignment = Enum.HorizontalAlignment.Right,
        FillDirection = Enum.FillDirection.Horizontal, SortOrder = Enum.SortOrder.LayoutOrder,
        Padding = UDim.new(0, 4), VerticalAlignment = Enum.VerticalAlignment.Center,
        Parent = extrasFrame,
    })

    local toggleData = {frame = frame, checkbox = check, toggled = toggled, flag = flag, extras = {}}

    local function setToggle(val)
        toggled = val; toggleData.toggled = val; Library.flags[flag] = val
        local tc = val and C.ACCENT or C.OFF
        tween(check, {BackgroundColor3 = tc}, TWEEN_FAST):Play()
        stroke(check, val and C.ACCENT or C.BORDER)
        checkMark.Visible = val
        cb(val)
    end
    local function onCheck(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then setToggle(not toggled) end
    end
    check.InputBegan:Connect(onCheck)
    nameLabel.InputBegan:Connect(onCheck)

    function toggleData:CreateColorPicker(cfg)
        cfg = cfg or {}
        local cpFlag = cfg.flag or flag .. "_color"
        local cpDefault = cfg.default or Color3.fromRGB(255, 255, 255)
        Library.flags[cpFlag] = cpDefault
        local cpBtn = create("TextButton", {
            BackgroundColor3 = cpDefault, Text = "", TextSize = 1,
            Size = UDim2.new(0, 18, 0, 14), BorderSizePixel = 0, AutoButtonColor = false,
            Parent = extrasFrame,
        })
        corner(cpBtn, 3); stroke(cpBtn, C.BORDER)
        cpBtn.MouseButton1Click:Connect(function()
            self._cpTarget = cpBtn
            self._cpCallback = function(c)
                cpBtn.BackgroundColor3 = c; Library.flags[cpFlag] = c
                if cfg.callback then cfg.callback(c) end
            end
            self._cpFlag = cpFlag
            local ba = cpBtn.AbsolutePosition
            self._colorPicker.Position = UDim2.new(0, ba.X - 180, 0, ba.Y - 100)
            self._colorPicker.Visible = true
        end)
        table.insert(toggleData.extras, {type = "colorpicker", frame = extrasFrame, button = cpBtn, flag = cpFlag})
        return toggleData
    end

    function toggleData:CreateKeybind(cfg)
        cfg = cfg or {}
        local kbFlag = cfg.flag or flag .. "_keybind"
        local kbDefault = cfg.default or "E"
        local kbMode = cfg.mode or "Toggle"
        Library.flags[kbFlag] = {key = kbDefault, mode = kbMode, active = false}
        local kbBtn = create("TextButton", {
            Text = "[" .. kbDefault .. "]", TextSize = 10, TextColor3 = C.SUBTEXT,
            BackgroundColor3 = C.ELEMENT, Size = UDim2.new(0, 36, 0, 14),
            BorderSizePixel = 0, AutoButtonColor = false, FontFace = FONT,
            Parent = extrasFrame,
        })
        corner(kbBtn, 3)
        local keyState = {held = false, toggled = false}
        local function rebind(k)
            if not k then return end
            local targetKeyCode, targetMouseType
            local ok = pcall(function() targetMouseType = Enum.UserInputType[k] end)
            if not targetMouseType then
                ok = pcall(function() targetKeyCode = Enum.KeyCode[k] end)
                if not ok then return end
            end
            Services.User_Input.InputBegan:Connect(function(input, gpe)
                if gpe then return end
                local m = (targetKeyCode and input.UserInputType == Enum.UserInputType.Keyboard and input.KeyCode == targetKeyCode)
                    or (targetMouseType and input.UserInputType == targetMouseType)
                if m then
                    keyState.held = true
                    local fd = Library.flags[kbFlag]
                    if fd then
                        if fd.mode == "Toggle" then keyState.toggled = not keyState.toggled; fd.active = keyState.toggled
                        elseif fd.mode == "Hold" then fd.active = true
                        else fd.active = true end
                    end
                end
            end)
            Services.User_Input.InputEnded:Connect(function(input)
                local m = (targetKeyCode and input.UserInputType == Enum.UserInputType.Keyboard and input.KeyCode == targetKeyCode)
                    or (targetMouseType and input.UserInputType == targetMouseType)
                if m then
                    keyState.held = false
                    local fd = Library.flags[kbFlag]
                    if fd and fd.mode == "Hold" then fd.active = false end
                end
            end)
        end
        rebind(kbDefault)
        kbBtn.MouseButton1Click:Connect(function()
            kbBtn.Text = "[...]"
            local conn; conn = Services.User_Input.InputBegan:Connect(function(input, gpe)
                local isMouse = input.UserInputType == Enum.UserInputType.MouseButton1 or
                    input.UserInputType == Enum.UserInputType.MouseButton2 or
                    input.UserInputType == Enum.UserInputType.MouseButton3
                if gpe and not isMouse then return end
                local kn
                if input.UserInputType == Enum.UserInputType.Keyboard then
                    kn = input.KeyCode == Enum.KeyCode.Backspace and nil or input.KeyCode.Name
                elseif isMouse then kn = input.UserInputType.Name end
                if kn ~= nil or input.UserInputType == Enum.UserInputType.Keyboard then
                    kbBtn.Text = kn and ("[" .. kn .. "]") or "[N/A]"
                    Library.flags[kbFlag] = {key = kn, mode = kbMode, active = false}
                    rebind(kn)
                    if cfg.callback then cfg.callback(kn, kbMode) end
                    if conn then conn:Disconnect() end
                end
            end)
        end)
        toggleData._keyMode = kbMode
        table.insert(toggleData.extras, {type = "keybind", frame = extrasFrame, button = kbBtn, flag = kbFlag})
        return toggleData
    end

    function toggleData:AddContextMenu()
