    Retake.win UI Library — Neverlose.cc Modern Theme
    API-compatible with 7_4_2026 (CreateTab, CreateMultiTab, CreateSection,
    CreateToggle, CreateSlider, CreateDropdown, CreateButton, CreateTextBox,
    CreateLabel, CreateWarning, AddContextMenu, CreateColorPicker,
    CreateKeybind, ShowKeybinds, RegisterKeybindLabel, Notify,
    SaveConfig, LoadConfig, DeleteConfig, GetConfigs, RefreshAll,
    SetMenuKeybind, Toggle, SetVisible, OnUnload, Unload, Destroy)
]]

local Services = {
    Players = game:GetService("Players"),
    User_Input = game:GetService("UserInputService"),
    Run_Service = game:GetService("RunService"),
    Tween_Service = game:GetService("TweenService"),
    CoreGui = game:GetService("CoreGui"),
}
local HttpService = game:GetService("HttpService")
local Local_Player = Services.Players.LocalPlayer
local TWEEN_FAST = TweenInfo.new(0.1, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
local TWEEN_SMOOTH = TweenInfo.new(0.18, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
local TWEEN_BOUNCE = TweenInfo.new(0.25, Enum.EasingStyle.Back, Enum.EasingDirection.Out)

-- ==================== THEME ====================
local C = {
    BG       = Color3.fromRGB(8, 8, 13),
    SIDEBAR  = Color3.fromRGB(10, 10, 16),
    SURFACE  = Color3.fromRGB(20, 22, 27),
    ELEMENT  = Color3.fromRGB(25, 27, 33),
    ACCENT   = Color3.fromRGB(78, 127, 252),
    TEXT     = Color3.fromRGB(180, 185, 195),
    SUBTEXT  = Color3.fromRGB(120, 125, 135),
    BORDER   = Color3.fromRGB(45, 48, 58),
    DARK     = Color3.fromRGB(14, 15, 20),
    SCROLL   = Color3.fromRGB(30, 32, 38),
    OFF      = Color3.fromRGB(55, 58, 68),
    WHITE    = Color3.fromRGB(255, 255, 255),
    BLACK    = Color3.fromRGB(0, 0, 0),
}
local FONT = Font.new("rbxasset://LuaPackages/Packages/_Index/BuilderIcons/BuilderIcons/BuilderIcons.json", Enum.FontWeight.Regular, Enum.FontStyle.Normal)
local FONT_BOLD = Font.new("rbxasset://LuaPackages/Packages/_Index/BuilderIcons/BuilderIcons/BuilderIcons.json", Enum.FontWeight.Bold, Enum.FontStyle.Normal)

local function create(className, props)
    local inst = Instance.new(className)
    for k, v in pairs(props) do inst[k] = v end
    return inst
end
local function corner(parent, radius)
    local c = Instance.new("UICorner"); c.CornerRadius = UDim.new(0, radius or 4); c.Parent = parent; return c
end
local function stroke(parent, color, thickness)
    local s = Instance.new("UIStroke"); s.Color = color or C.BORDER; s.Thickness = thickness or 1; s.Parent = parent; return s
end
local function tween(inst, props, info)
    return Services.Tween_Service:Create(inst, info or TWEEN_FAST, props)
end
local function label(parent, text, size, color, font, props)
    local l = create("TextLabel", {
        Parent = parent, Text = text or "", TextSize = size or 13,
        TextColor3 = color or C.TEXT, FontFace = font or FONT,
        BackgroundTransparency = 1, BorderSizePixel = 0,
        TextXAlignment = Enum.TextXAlignment.Left,
    })
    for k, v in pairs(props or {}) do l[k] = v end
    return l
end

-- ==================== LIBRARY ====================
