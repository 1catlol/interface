function Library:CreateDropdown(section, config)
    local name = config.name or "Dropdown"; local flag = config.flag or name:lower():gsub("%s+", "_")
    local options = config.options or {}; local multi = config.multi or false
    local default = config.default or (multi and {} or (options[1] or ""))
    local cb = config.callback or function() end
    if multi and type(default) == "string" then default = default ~= "" and {default} or {} end
    Library.flags[flag] = default

    local frame = create("Frame", {
        BackgroundTransparency = 1, AutomaticSize = Enum.AutomaticSize.Y,
        Size = UDim2.new(1, 0, 0, 24), BorderSizePixel = 0, Parent = section.elements,
    })
    local ddBtn = create("TextButton", {
        BackgroundColor3 = C.ELEMENT, Text = "", TextSize = 1,
        Size = UDim2.new(1, -12, 0, 22), Position = UDim2.new(0, 6, 0, 0),
        BorderSizePixel = 0, AutoButtonColor = false, Parent = frame,
    })
    corner(ddBtn, 4); stroke(ddBtn, C.BORDER)
    local btnLabel = label(ddBtn, name, 12, C.TEXT, FONT, {
        Position = UDim2.new(0, 6, 0, 0), Size = UDim2.new(1, -12, 1, 0),
        TextYAlignment = Enum.TextYAlignment.Center,
    })

    local list = create("Frame", {
        BackgroundColor3 = C.SURFACE, AutomaticSize = Enum.AutomaticSize.Y,
        Size = UDim2.new(1, -12, 0, 0), Position = UDim2.new(0, 6, 0, 24),
        BorderSizePixel = 0, Visible = false, ClipsDescendants = true, Parent = frame,
    })
    corner(list, 4); stroke(list, C.BORDER)
    create("UIListLayout", {Padding = UDim.new(0, 2), SortOrder = Enum.SortOrder.LayoutOrder, Parent = list})

    local selected = default; local selectedSet = {}
    local optionBtns = {}
    if multi then for _, v in ipairs(default) do selectedSet[v] = true end
    else selectedSet[default] = true end

    local function selectOption(opt)
        if multi then
            selectedSet[opt] = not selectedSet[opt]
            local sl = {}
            for _, o in ipairs(options) do if selectedSet[o] then table.insert(sl, o) end end
            selected = sl; Library.flags[flag] = sl
            for _, b in ipairs(optionBtns) do b.TextColor3 = selectedSet[b.Text] and C.ACCENT or C.SUBTEXT end
            local dt = #sl > 0 and table.concat(sl, ", ") or name
            if #dt > 30 then dt = dt:sub(1, 27) .. "..." end
            btnLabel.Text = dt; cb(sl)
        else
            selected = opt; selectedSet = {[opt] = true}
            Library.flags[flag] = opt; cb(opt)
            for _, b in ipairs(optionBtns) do b.TextColor3 = b.Text == opt and C.ACCENT or C.SUBTEXT end
            btnLabel.Text = opt; list.Visible = false
        end
    end

    for _, opt in ipairs(options) do
        local ob = create("TextButton", {
            BackgroundColor3 = C.ELEMENT, Text = tostring(opt), TextSize = 12,
            TextColor3 = selectedSet[opt] and C.ACCENT or C.SUBTEXT,
            Size = UDim2.new(1, 0, 0, 20), BorderSizePixel = 0,
            AutoButtonColor = false, FontFace = FONT, Parent = list,
        })
        corner(ob, 3)
        ob.MouseButton1Click:Connect(function() selectOption(opt) end)
        table.insert(optionBtns, ob)
    end

    ddBtn.MouseButton1Click:Connect(function() list.Visible = not list.Visible end)
    if multi then for _, v in ipairs(default) do selectOption(v) end
    elseif default ~= "" then selectOption(default) end

    local function refreshOptions(newOptions)
        for _, b in ipairs(optionBtns) do b:Destroy() end
        table.clear(optionBtns); options = newOptions or {}; selectedSet = {}; list:ClearAllChildren()
        for _, opt in ipairs(options) do
            local ob = create("TextButton", {
                BackgroundColor3 = C.ELEMENT, Text = tostring(opt), TextSize = 12,
                TextColor3 = C.SUBTEXT, Size = UDim2.new(1, 0, 0, 20), BorderSizePixel = 0,
                AutoButtonColor = false, FontFace = FONT, Parent = list,
            })
            corner(ob, 3)
            ob.MouseButton1Click:Connect(function() selectOption(opt) end)
            table.insert(optionBtns, ob)
        end
    end

    table.insert(self._syncList, {
        flag = flag, multi = multi,
        apply = function(val)
            if val == nil then val = Library.flags[flag] end
            if val == nil then return end
            if multi then
                selectedSet = {}
                if type(val) == "table" then for _, v in ipairs(val) do selectedSet[v] = true end end
                for _, b in ipairs(optionBtns) do b.TextColor3 = selectedSet[b.Text] and C.ACCENT or C.SUBTEXT end
                local dt = #val > 0 and table.concat(val, ", ") or name
                if #dt > 30 then dt = dt:sub(1, 27) .. "..." end
                btnLabel.Text = dt
            else
                for _, b in ipairs(optionBtns) do b.TextColor3 = b.Text == val and C.ACCENT or C.SUBTEXT end
                if val ~= "" then btnLabel.Text = val end
            end
        end,
    })
    return {frame = frame, options = optionBtns, listFrame = list, RefreshOptions = refreshOptions}
end

