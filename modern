function Library:SaveConfig(name)
    local function s(v)
        if typeof(v) == "Color3" then return {__c = {v.R, v.G, v.B}} elseif type(v) == "table" then local t = {}; for kk, vv in pairs(v) do t[kk] = s(vv) end; return t end; return v
    end
    local f = {}; for k, v in pairs(Library.flags) do if type(k) == "string" then f[k] = s(v) end end
    if not isfolder(self._configFolder) then makefolder(self._configFolder) end
    writefile(self._configFolder .. "/" .. name .. ".json", HttpService:JSONEncode(f))
    writefile(self._configFolder .. "/_last.txt", name)
end

function Library:LoadConfig(name)
    local function d(v)
        if type(v) == "table" and v.__c then return Color3.new(v.__c[1], v.__c[2], v.__c[3]) elseif type(v) == "table" then local t = {}; for kk, vv in pairs(v) do t[kk] = d(vv) end; return t end; return v
    end
    local p = self._configFolder .. "/" .. name .. ".json"
    if not isfile(p) then return false end
    local ok, data = pcall(function() return HttpService:JSONDecode(readfile(p)) end)
    if not ok or type(data) ~= "table" then return false end
    for k, v in pairs(data) do Library.flags[k] = d(v) end
    writefile(self._configFolder .. "/_last.txt", name); self:RefreshAll(); return true
end

function Library:GetConfigs()
    local c = {}; if not isfolder(self._configFolder) then return c end
    for _, f in ipairs(listfiles(self._configFolder)) do local n = f:match("([^/\\]+)%.json$"); if n then table.insert(c, n) end end; return c
end
function Library:DeleteConfig(name) local p = self._configFolder .. "/" .. name .. ".json"; if isfile(p) then delfile(p) end end
function Library:RefreshAll() for _, s in ipairs(self._syncList) do s.apply() end end
function Library:ShowKeybinds(v) self.keybindPanel.Visible = v end
function Library:RegisterKeybindLabel(flag, dn)
    local fr = create("Frame", {BackgroundColor3 = C.ELEMENT, Size = UDim2.new(1, 0, 0, 18), BorderSizePixel = 0, Parent = self._kbHolder}); corner(fr, 3)
    local l = label(fr, "[N/A] " .. (dn or "keybind"), 11, C.TEXT, FONT, {Size = UDim2.new(1, 0, 1, 0), TextYAlignment = Enum.TextYAlignment.Center})
    self._keybindNames[flag] = dn; self._keybindLabels[flag] = l; self._keybindFrames[flag] = fr; return l
end
function Library:Toggle() if self.main.Visible then self:SetVisible(false) else self:SetVisible(true) end end
function Library:SetVisible(v) if v then self.main.Visible = true else self.main.Visible = false; if self._colorPicker then self._colorPicker.Visible = false end end end
function Library:SetMenuKeybind(k) self._menuKeybind = k end
function Library:CreateWarning(t, tx, cb) if cb then cb(true) end end
function Library:OnUnload(cb) self._onUnload = cb end
function Library:Unload() if self._kbUpdateConn then self._kbUpdateConn:Disconnect() end; self.screenGui:Destroy(); if self._onUnload then self._onUnload() end end
function Library:Destroy() self:Unload() end

return Library
