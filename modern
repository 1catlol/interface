        }
        table.insert(self._openContexts, {popup = popup, open = ctxOpen})
        toggleData._ctxSection = ctxSection
        return ctxSection
    end

    table.insert(self._syncList, {
        flag = flag,
        apply = function(val)
            if val == nil then val = Library.flags[flag] end
            if val == nil then return end
            setToggle(val)
        end,
    })
    return toggleData
end

-- ==================== SLIDER ====================
function Library:CreateSlider(section, config)
    local name = config.name or "Slider"; local flag = config.flag or name:lower():gsub("%s+", "_")
    local minV, maxV = config.min or 0, config.max or 100
    local step = config.step or 1; local default = config.default or minV
    local cb = config.callback or function() end
    Library.flags[flag] = default

    local frame = create("Frame", {
        BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 36), BorderSizePixel = 0,
        Parent = section.elements,
    })
    local nameLabel = label(frame, name, 12, C.TEXT, FONT, {
        Position = UDim2.new(0, 6, 0, 2), Size = UDim2.new(1, -12, 0, 14),
    })
    local bar = create("Frame", {
        BackgroundColor3 = C.OFF, Size = UDim2.new(1, -12, 0, 8),
        Position = UDim2.new(0, 6, 0, 20), BorderSizePixel = 0, Parent = frame,
    })
    corner(bar, 4)
    local fill = create("Frame", {
        BackgroundColor3 = C.ACCENT, Size = UDim2.new(0, 0, 1, 0), BorderSizePixel = 0, Parent = bar,
    })
    corner(fill, 4)
    local valLabel = label(frame, tostring(default), 11, C.SUBTEXT, FONT, {
        Position = UDim2.new(1, -50, 0, 2), Size = UDim2.new(0, 44, 0, 14),
        TextXAlignment = Enum.TextXAlignment.Right,
    })

    local function update(frac)
        local val = minV + (maxV - minV) * frac
        val = step > 0 and math.floor(val / step + 0.5) * step or val
        val = math.clamp(val, minV, maxV)
        local f = (val - minV) / (maxV - minV)
        tween(fill, {Size = UDim2.new(f, 0, 1, 0)}, TWEEN_FAST):Play()
        local dv = step == 1 and math.floor(val) or string.format("%.2f", val)
        valLabel.Text = dv .. " / " .. maxV
        Library.flags[flag] = val; cb(val)
    end
    update((default - minV) / (maxV - minV))

    local drag = false
    bar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            drag = true
        end
    end)
    Services.User_Input.InputChanged:Connect(function(input)
        if not drag then return end
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            local ap = bar.AbsolutePosition; local sz = bar.AbsoluteSize
            update(math.clamp((input.Position.X - ap.X) / sz.X, 0, 1))
        end
    end)
    Services.User_Input.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            drag = false
        end
    end)

    table.insert(self._syncList, {
        flag = flag,
        apply = function(val)
            if val == nil then val = Library.flags[flag] end
            if val == nil then return end
            update((val - minV) / (maxV - minV))
        end,
    })
    return {frame = frame, fill = fill, nameLabel = nameLabel, valueLabel = valLabel}
end

