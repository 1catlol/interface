        create("UIListLayout", {
            HorizontalFlex = Enum.UIFlexAlignment.Fill,
            SortOrder = Enum.SortOrder.LayoutOrder, Padding = UDim.new(0, 2), Parent = popEls,
        })

        local ctxOpen = {value = false}
        ctxBtn.MouseButton1Click:Connect(function()
            ctxOpen.value = not ctxOpen.value
            if ctxOpen.value then
                local ba = ctxBtn.AbsolutePosition
                popup.Position = UDim2.new(0, ba.X - 195, 0, ba.Y + 16)
                popup.Visible = true
            else
                popup.Visible = false
            end
        end)

        local ctxSection = {
            frame = popup, inner = popup, elements = popEls, name = "context",
